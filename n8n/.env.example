# ══════════════════════════════════════════════════════════
# Classic CQ — n8n Environment Variables
# ══════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores reais:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────
# URL do projeto Supabase (Settings > API > URL)
SUPABASE_URL=https://nvqxsulntpftcwtkjedu.supabase.co

# Service Role Key (Settings > API > service_role)
# NUNCA usar a anon key aqui — n8n precisa de acesso completo
SUPABASE_SERVICE_KEY=eyJ...cole_aqui

# ── API ATAK ──────────────────────────────────────────────
# Token de autenticacao da API ATAK
ATAK_API_TOKEN=cole_token_atak_aqui

# URL base da API ATAK
ATAK_API_BASE_URL=https://api.atak.com.br/v1

# ── n8n Config ────────────────────────────────────────────
# Timezone (importante para os crons)
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# Autenticacao do painel n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque_esta_senha

# Webhook URL (para o dedup endpoint)
# Em producao, configure o dominio real
WEBHOOK_URL=http://localhost:5678

# ── Notificacoes (opcional) ───────────────────────────────
# Slack webhook para alertas de qualidade
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# WhatsApp (Twilio ou Z-API)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
